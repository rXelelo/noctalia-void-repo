revision=0
short_desc="A sleek and minimal desktop shell thoughtfully crafted for Wayland, built with Quickshell."
maintainer="Rain Xelelo <rXelelo@outlook.com"
license="MIT"
homepage="https://github.com/noctalia-dev/noctalia-shell"
